rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    function isStaff() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager']
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.id is string &&
               data.email is string && data.email.size() <= 256 &&
               data.plan in ['Free', 'Creator', 'Pro', 'Enterprise'] &&
               data.role in ['admin', 'manager', 'user'];
      }

      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == 'user' && incoming().isApproved == false;
      
      allow update: if isSignedIn() && (
        // Admin update anything
        isAdmin() ||
        // User update their own non-sensitive fields
        (isOwner(userId) && isValidUser(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['favoriteVoices', 'apiKey']))
      );
    }

    // 2. Activation Requests
    match /activationRequests/{requestId} {
      function isValidRequest(data) {
        return data.id is string &&
               data.userId is string &&
               data.plan is string &&
               data.status in ['pending', 'approved', 'rejected'];
      }

      allow get: if isSignedIn() && (isOwner(existing().userId) || isStaff());
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidRequest(incoming()) && 
                    incoming().status == 'pending' && isValidId(requestId);
      
      allow update: if isStaff() && isValidRequest(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    // 3. Feedback
    match /feedback/{feedbackId} {
      function isValidFeedback(data) {
        return data.id is string &&
               data.userId is string &&
               data.message is string && data.message.size() <= 5000 &&
               data.rating is number;
      }

      allow read: if isStaff();
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidFeedback(incoming()) && isValidId(feedbackId);
    }
  }
}
