# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# LOCAL_AI_BRIDGE_URL: Points to your self-hosted FastAPI server.
# Default is http://localhost:8000 for local development.
LOCAL_AI_BRIDGE_URL="http://localhost:8000"

# HEYGEN_API_KEY: Optional for HeyGen video generation features.
HEYGEN_API_KEY=""

# OPENAI_API_KEY: Optional for additional AI text processing if needed
OPENAI_API_KEY=""

# VITE_ADMIN_WHATSAPP_NUMBER: Admin WhatsApp number for activation requests
VITE_ADMIN_WHATSAPP_NUMBER="923122180862"
